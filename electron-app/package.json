{
  "name": "app_programming_language",
  "version": "1.0.0",
  "description": "[task.md](task.md)",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:wasm:rust:interpreter": "cd rust-interpreter && wasm-pack build --target web --out-dir ../src/wasm/interpreter_lib",
    "build:wasm:rust:crypto": "cd rust-crypto-lib && wasm-pack build --target web --out-dir ../src/wasm/crypto_lib",
    "build": "npm run build:wasm:rust:crypto && npm run build:wasm:rust:interpreter",
    "dist": "npm run build && electron-builder",
    "start": "npm run build && electron .",
    "dev": "tsc -w",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arthur10o/app_programming_language.git"
  },
  "author": {
    "name": "Arthur",
    "email": "test@test.test"
  },
  "keywords": [],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/arthur10o/app_programming_language/issues"
  },
  "homepage": "https://github.com/arthur10o/app_programming_language#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.7.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.aplusplus.ide",
    "productName": "A++ IDE",
    "files": [
      "dist/**/*",
      "public/**/*",
      "rust-crypto-lib/pkg/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/src/app/",
        "to": "app/"
      },
      {
        "from": "dist/src/common/",
        "to": "common/"
      },
      {
        "from": "dist/src/data/",
        "to": "data/"
      },
      {
        "from": "dist/renderer.js",
        "to": "renderer.js"
      },
      {
        "from": "dist/wasm/crypto_lib/",
        "to": "wasm/crypto_lib/"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "public/assets/icons/app-logo.png"
    }
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
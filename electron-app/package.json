{
  "name": "app_programming_language",
  "version": "1.0.0",
  "description": "[task.md](task.md)",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "wasm": "cd rust-crypto-lib && wasm-pack build --target web",
    "dist": "npm run wasm && electron-builder",
    "build": "tsc",
    "dev": "ts-node src/main/main.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arthur10o/app_programming_language.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/arthur10o/app_programming_language/issues"
  },
  "homepage": "https://github.com/arthur10o/app_programming_language#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.7.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.aplusplus.ide",
    "productName": "A++ IDE",
    "files": [
      "src/**/*",
      "main.js",
      "preload.js",
      "rust/pkg/**/*",
      "package.json",
      "public/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "public/assets/icons/app-logo.png"
    }
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}